{
  "expo": {
    "name": "Valorize",
    "slug": "valorize",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valorize.app"
    },
    "android": {
      "package": "com.valorize.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#101E36",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f65ff930-f63b-4dfa-9aee-eade7e424f06"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f65ff930-f63b-4dfa-9aee-eade7e424f06"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "ronaldosantos-ais-team",
    "plugins": [
      "expo-asset",
      "expo-secure-store"
    ]
  }
}
